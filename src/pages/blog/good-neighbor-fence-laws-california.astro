				<td style="padding: 12px; border: 1px solid #ddd;">6' wood privacy fence</td>
				<td style="padding: 12px; border: 1px solid #ddd;">8' concrete block wall</td>
			</tr>
			<tr>
				<td style="padding: 12px; border: 1px solid #ddd;">Material choice</td>
